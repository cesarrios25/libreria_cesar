@model LibreriaCesar.Models.Prestamo

<h2>Detalle del Préstamo</h2>

<div class="card p-3">

    <p><strong>ID:</strong> @Model.IdPrestamo</p>

    <p><strong>Usuario:</strong> @Model.Usuario.Nombre</p>

    <p><strong>Libro:</strong> @Model.Libro.Titulo</p>

    <p><strong>Fecha préstamo:</strong> @Model.FechaPrestamo</p>

    <p><strong>Fecha devolución:</strong> @Model.FechaDevolucion</p>

</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Volver</a>