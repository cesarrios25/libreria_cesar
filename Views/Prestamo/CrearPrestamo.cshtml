@{
    ViewData["Title"] = "Crear Préstamo";
}

<div class="form-card">
    <div class="table-header" style="padding: 0 0 1.5rem 0; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem;">
        <div class="table-title">Nuevo préstamo</div>
        <a asp-action="Index" asp-controller="Prestamo" class="btn-ghost">← Volver</a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div style="background:#FDF0EE;border:1px solid rgba(192,57,43,0.25);border-radius:var(--radius);padding:0.75rem 1rem;margin-bottom:1.5rem;color:var(--danger);font-size:13px;">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="CrearPrestamo" asp-controller="Prestamo" method="post">
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Usuario</label>
                <select name="usuarioId" class="form-input">
                    <option value="">Selecciona un usuario</option>
                    @foreach (var usuario in ViewBag.Usuarios)
                    {
                        <option value="@usuario.IdUsuario">@usuario.Nombre @usuario.Apellido</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Libro</label>
                <select name="libroId" class="form-input">
                    <option value="">Selecciona un libro</option>
                    @foreach (var libro in ViewBag.Libros)
                    {
                        <option value="@libro.IdLibro">@libro.Titulo (@libro.StockDisponible disponibles)</option>
                    }
                </select>
            </div>
        </div>

        <div class="form-footer">
            <button type="submit" class="btn-primary">Registrar préstamo</button>
            <a asp-action="Index" asp-controller="Prestamo" class="btn-ghost">Cancelar</a>
        </div>
    </form>
</div>