@model LibreriaCesar.Models.Libro

@{
    ViewData["Title"] = "Editar Libro";
}

<div class="form-card">
    <div class="table-header" style="padding: 0 0 1.5rem 0; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem;">
        <div class="table-title">Editar libro</div>
        <a asp-action="Index" asp-controller="Libro" class="btn-ghost">← Volver</a>
    </div>

    <form asp-action="EditarLibro" asp-controller="Libro" method="post">

        <input type="hidden" asp-for="IdLibro" />

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Título</label>
                <input asp-for="Titulo" class="form-input" />
                <span asp-validation-for="Titulo" style="color:var(--danger);font-size:12px"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Autor</label>
                <input asp-for="Autor" class="form-input" />
                <span asp-validation-for="Autor" style="color:var(--danger);font-size:12px"></span>
            </div>

            <div class="form-group">
                <label class="form-label">ISBN</label>
                <input asp-for="ISBN" class="form-input" />
                <span asp-validation-for="ISBN" style="color:var(--danger);font-size:12px"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Género</label>
                <input asp-for="Genero" class="form-input" />
                <span asp-validation-for="Genero" style="color:var(--danger);font-size:12px"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Año de publicación</label>
                <input asp-for="AnoPublicacion" class="form-input" />
                <span asp-validation-for="AnoPublicacion" style="color:var(--danger);font-size:12px"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Stock total</label>
                <input asp-for="StockTotal" class="form-input" />
                <span asp-validation-for="StockTotal" style="color:var(--danger);font-size:12px"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Stock disponible</label>
                <input asp-for="StockDisponible" class="form-input" />
                <span asp-validation-for="StockDisponible" style="color:var(--danger);font-size:12px"></span>
            </div>
        </div>

        <div class="form-footer">
            <button type="submit" class="btn-primary">Guardar cambios</button>
            <a asp-action="Index" asp-controller="Libro" class="btn-ghost">Cancelar</a>
        </div>

    </form>
</div>