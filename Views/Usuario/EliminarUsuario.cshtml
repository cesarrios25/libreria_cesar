@model LibreriaCesar.Models.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<div class="form-card">
    <div class="table-header" style="padding: 0 0 1.5rem 0; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem;">
        <div class="table-title">Eliminar usuario</div>
        <a asp-action="Index" asp-controller="Usuario" class="btn-ghost">← Volver</a>
    </div>

    <p style="color:var(--text-secondary);margin-bottom:1.5rem;">
        ¿Estás seguro que deseas eliminar este usuario? Esta acción no se puede deshacer.
    </p>

    <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.5rem;margin-bottom:1.5rem;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div>
                <div class="form-label" style="margin-bottom:4px;">Nombre completo</div>
                <div style="font-size:14px;font-weight:500;">@Model.Nombre @Model.Apellido</div>
            </div>
            <div>
                <div class="form-label" style="margin-bottom:4px;">Email</div>
                <div style="font-size:14px;color:var(--text-secondary)">@Model.Email</div>
            </div>
            <div>
                <div class="form-label" style="margin-bottom:4px;">Teléfono</div>
                <div style="font-size:14px;color:var(--text-secondary)">@Model.Telefono</div>
            </div>
            <div>
                <div class="form-label" style="margin-bottom:4px;">Fecha registro</div>
                <div style="font-size:14px;color:var(--text-secondary)">@Model.FechaRegistro.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>

    <form asp-action="EliminarUsuario" asp-controller="Usuario" method="post">
        <input type="hidden" asp-for="IdUsuario" />
        <div class="form-footer" style="padding-top:0;border-top:none;">
            <button type="submit" class="btn-danger">Sí, eliminar</button>
            <a asp-action="Index" asp-controller="Usuario" class="btn-ghost">Cancelar</a>
        </div>
    </form>
</div>